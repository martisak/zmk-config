#include <dt-bindings/zmk/matrix_transform.h>
#include <physical_layouts.dtsi>

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,matrix_transform = &default_transform;
    };

    // Physical layout for ZMK Studio. Key positions and sizes are in
    // 1/100 keyunit; rotation in 1/100 degree. Derived from the
    // geometry in config/skoldpad.json. Order matches default_transform.
    physical_layout0: physical_layout_0 {
        compatible = "zmk,physical-layout";
        display-name = "Skoldpad";
        transform = <&default_transform>;
        kscan = <&kscan0>;

        keys  //                     w   h    x    y     rot    rx    ry
            = <&key_physical_attrs 100 100    0    0       0     0     0>
            , <&key_physical_attrs 100 100  100 (-26)      0     0     0>
            , <&key_physical_attrs 100 100  200 (-126)     0     0     0>
            , <&key_physical_attrs 100 100  300 (-147)     0     0     0>
            , <&key_physical_attrs 100 100  400 (-116)     0     0     0>
            , <&key_physical_attrs 100 100  500 (-106)     0     0     0>
            , <&key_physical_attrs 100 100 1000 (-106)     0     0     0>
            , <&key_physical_attrs 100 100 1100 (-116)     0     0     0>
            , <&key_physical_attrs 100 100 1200 (-147)     0     0     0>
            , <&key_physical_attrs 100 100 1300 (-126)     0     0     0>
            , <&key_physical_attrs 100 100 1400 (-26)      0     0     0>
            , <&key_physical_attrs 100 100 1500    0       0     0     0>
            , <&key_physical_attrs 100 100    0  100       0     0     0>
            , <&key_physical_attrs 100 100  100   74       0     0     0>
            , <&key_physical_attrs 100 100  200 (-26)      0     0     0>
            , <&key_physical_attrs 100 100  300 (-47)      0     0     0>
            , <&key_physical_attrs 100 100  400 (-16)      0     0     0>
            , <&key_physical_attrs 100 100  500 (-6)       0     0     0>
            , <&key_physical_attrs 100 100 1000 (-6)       0     0     0>
            , <&key_physical_attrs 100 100 1100 (-16)      0     0     0>
            , <&key_physical_attrs 100 100 1200 (-47)      0     0     0>
            , <&key_physical_attrs 100 100 1300 (-26)      0     0     0>
            , <&key_physical_attrs 100 100 1400   74       0     0     0>
            , <&key_physical_attrs 100 100 1500  100       0     0     0>
            , <&key_physical_attrs 100 100    0  200       0     0     0>
            , <&key_physical_attrs 100 100  100  174       0     0     0>
            , <&key_physical_attrs 100 100  200   74       0     0     0>
            , <&key_physical_attrs 100 100  300   53       0     0     0>
            , <&key_physical_attrs 100 100  400   84       0     0     0>
            , <&key_physical_attrs 100 100  500   94       0     0     0>
            , <&key_physical_attrs 100 100 1000   94       0     0     0>
            , <&key_physical_attrs 100 100 1100   84       0     0     0>
            , <&key_physical_attrs 100 100 1200   53       0     0     0>
            , <&key_physical_attrs 100 100 1300   74       0     0     0>
            , <&key_physical_attrs 100 100 1400  174       0     0     0>
            , <&key_physical_attrs 100 100 1500  200       0     0     0>
            , <&key_physical_attrs 100 100  250  144       0     0     0>
            , <&key_physical_attrs 100 100  350  144       0     0     0>
            , <&key_physical_attrs 100 100  450  144    2000   300   300>
            , <&key_physical_attrs 100 150  550  144    2000   300   300>
            , <&key_physical_attrs 100 150  650  144    2000   300   300>
            , <&key_physical_attrs 100 150  850  184  (-2000) 1200   300>
            , <&key_physical_attrs 100 150  950  184  (-2000) 1200   300>
            , <&key_physical_attrs 100 100 1050  184  (-2000) 1200   300>
            , <&key_physical_attrs 100 100 1150  184       0     0     0>
            , <&key_physical_attrs 100 100 1250  184       0     0     0>
            ;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        rows = <4>;
        columns = <16>;

        map = <
        RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5)                                  RC(0,10) RC(0,11) RC(0,12) RC(0,13) RC(0,14) RC(0,15) 
        RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)                                  RC(1,10) RC(1,11) RC(1,12) RC(1,13) RC(1,14) RC(1,15) 
        RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5)                                  RC(2,10) RC(2,11) RC(2,12) RC(2,13) RC(2,14) RC(2,15) 
                        RC(3,2) RC(3,3)         RC(3,5) RC(3,6) RC(3,7)  RC(3,8) RC(3,9) RC(3,10)          RC(3,12) RC(3,13)
        >;
    };

    kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        label = "KSCAN";
    };

    encoder_left: encoder_left {
        compatible = "alps,ec11";
        label = "LEFT_ENCODER";
        a-gpios = <&pro_micro 19 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
        b-gpios = <&pro_micro 20 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
        steps = <30>;
        status = "disabled";
    };

    encoder_right: encoder_right {
        compatible = "alps,ec11";
        label = "RIGHT_ENCODER";
        a-gpios = <&pro_micro 19 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
        b-gpios = <&pro_micro 20 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
        steps = <30>;
        status = "disabled";
    };

    sensors {
        compatible = "zmk,keymap-sensors";
        sensors = <&encoder_left &encoder_right>;
        triggers-per-rotation = <15>;
    };
};